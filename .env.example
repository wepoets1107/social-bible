# 社牛圣经 / The Social Bible — 配置文件
# 复制此文件为 .env，填入真实信息

# === SMTP 邮件（必填） ===
SMTP_SENDER="yourname@126.com"       # 发件邮箱
SMTP_RECIPIENT="you@gmail.com"       # 收件邮箱（发送目标）
SMTP_PASS="your-smtp-auth-code"      # SMTP 授权码（不是邮箱登录密码）
# SMTP_SERVER="smtp.126.com"         # 可选，默认 smtp.126.com
# SMTP_PORT="465"                    # 可选，默认 465 (SSL)

# === AI API（必填） ===
DEEPSEEK_API_KEY="sk-your-api-key"   # DeepSeek API Key
# DEEPSEEK_BASE_URL="https://api.deepseek.com"  # 可选
